generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum BusinessType {
  REAL_ESTATE
  ADVERTISING
  RETAIL
  CONSTRUCTION
  TECHNOLOGY
  HEALTHCARE
  FINANCE
  OTHER
}

enum CompanyType {
  CORPORATION
  LLC
  SOLE_PROPRIETOR
  PARTNERSHIP
  NON_PROFIT
  OTHER
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assignments Assignment[]
  notes       Note[]
}

// ─── Company & related sub-tables ────────────────────────────────────────────

model Company {
  id              Int           @id @default(autoincrement())
  businessName    String
  supportNumber   String?       @unique
  businessType    BusinessType?
  companyType     CompanyType?
  companyActivity String?       @db.Text
  country         String?
  qbPlan          String?
  status          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  legalInfo     LegalInfo?
  contactInfo   ContactInfo?
  billing       Billing?
  accountant    Accountant?
  assignments   Assignment[]
  todos         Todo[]
  taskSchedules TaskSchedule[]
  links         Link[]
  notes         Note[]
}

model LegalInfo {
  id          Int      @id @default(autoincrement())
  companyId   Int      @unique
  neq         String?
  revenueQcId String?
  craBn       String?
  fiscalYear  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], map: "fk_legal_info_company")
}

model ContactInfo {
  id           Int      @id @default(autoincrement())
  companyId    Int      @unique
  privateEmail String?
  privatePhone String?
  personalName String?
  storeNumber  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], map: "fk_contact_info_company")
}

model Billing {
  id              Int      @id @default(autoincrement())
  companyId       Int      @unique
  billingEmail    String?
  billingPassword String? // stored AES-256 encrypted — never plaintext
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], map: "fk_billing_company")
}

model Accountant {
  id        Int      @id @default(autoincrement())
  companyId Int      @unique
  name      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], map: "fk_accountant_company")
}

// ─── Assignments (User ↔ Company) ────────────────────────────────────────────

model Assignment {
  id         Int      @id @default(autoincrement())
  userId     Int
  companyId  Int
  assignedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], map: "fk_assignment_user")
  company Company @relation(fields: [companyId], references: [id], map: "fk_assignment_company")

  @@unique([userId, companyId])
}

// ─── Tasks & Todos ───────────────────────────────────────────────────────────

model Task {
  id          Int       @id @default(autoincrement())
  title       String    @unique
  description String?   @db.Text
  isGeneral   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  todos     Todo[]
  schedules TaskSchedule[]
}

// Recurring schedule for a task assigned to a company.
// cycle = recurrence interval in days.
// deletedAt = soft-delete: stops future todo generation without deleting history.
model TaskSchedule {
  id        Int       @id @default(autoincrement())
  taskId    Int
  companyId Int
  cycle     Int // days between recurrences
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  task    Task    @relation(fields: [taskId], references: [id], map: "fk_schedule_task")
  company Company @relation(fields: [companyId], references: [id], map: "fk_schedule_company")
  todos   Todo[]

  @@unique([taskId, companyId])
}

// ─── Links ───────────────────────────────────────────────────────────────────

model Link {
  id        Int    @id @default(autoincrement())
  companyId Int
  label     String
  url       String

  company Company @relation(fields: [companyId], references: [id], map: "fk_link_company")
}

// ─── Notes ───────────────────────────────────────────────────────────────────

// Private notes on a company. Each note is only visible to the user who wrote it.
model Note {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  note      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], map: "fk_note_company")
  user    User    @relation(fields: [userId], references: [id], map: "fk_note_user")
}

// Individual todo instance. scheduleId is set when generated by a TaskSchedule.
// Standalone (one-time) todos have scheduleId = null.
model Todo {
  id         Int       @id @default(autoincrement())
  taskId     Int
  companyId  Int
  scheduleId Int?
  dueDate    DateTime?
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  task     Task          @relation(fields: [taskId], references: [id], map: "fk_todo_task")
  company  Company       @relation(fields: [companyId], references: [id], map: "fk_todo_company")
  schedule TaskSchedule? @relation(fields: [scheduleId], references: [id], map: "fk_todo_schedule")
}
